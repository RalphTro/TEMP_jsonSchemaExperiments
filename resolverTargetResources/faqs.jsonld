            "id": "https://example.com/01/09520123456788/faqs#q1",
            "name": "How do I connect the kettle to Wi-Fi?",
            "acceptedAnswer": {
                "type": "Answer",
                "text": "Download the Acme Home app, switch on the kettle, and follow the in-app instructions to connect to your home Wi-Fi network."
            }
        },
        {
            "type": "Question",
            "id": "https://example.com/01/09520123456788/faqs#q2",
            "name": "Is the kettle compatible with voice assistants?",
            "acceptedAnswer": {
                "type": "Answer",
                "text": "Yes, the Acme Smart Kettle 3000 supports major voice assistants such as Alexa and Google Assistant."
            }
        },
        {
            "type": "Question",
            "id": "https://example.com/01/09520123456788/faqs#q3",
            "name": "Can I set temperature presets?",
            "acceptedAnswer": {
                "type": "Answer",
                "text": "Yes, the kettle allows you to define and save multiple temperature presets via the mobile app."
            }
